{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": ["src/renderer/src/**/*"],
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["src/renderer/src/*"],
      "@stores/*": ["src/renderer/src/stores/*"],
      "@components/*": ["src/renderer/src/components/*"]
    }
  }
}
